# ─── Zoho API Credentials ────────────────────────────────────────────────────
# Register your app at https://api-console.zoho.com/
# Select "Server-based Applications" as the client type

ZOHO_CLIENT_ID=your_client_id_here
ZOHO_CLIENT_SECRET=your_client_secret_here

# The redirect URI you registered in the Zoho Developer Console
# For local dev, http://localhost:8080/callback works fine
ZOHO_REDIRECT_URI=http://localhost:8080/callback

# ─── Regional Data Centre ─────────────────────────────────────────────────────
# Change if your Zoho account is on a regional DC:
#   EU:        https://accounts.zoho.eu
#   Australia: https://accounts.zoho.com.au
#   India:     https://accounts.zoho.in
#   Japan:     https://accounts.zoho.jp
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com

# Corresponding Mail API base URL (match region to accounts URL)
ZOHO_MAIL_API_URL=https://mail.zoho.com/api

# ─── Token Storage ────────────────────────────────────────────────────────────
# Local file where OAuth tokens are cached — add to .gitignore
TOKEN_FILE=.zoho_tokens.json
